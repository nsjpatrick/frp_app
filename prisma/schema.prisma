generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users     User[]
  customers Customer[]
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  role       Role     @default(SALES)
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  createdAt  DateTime @default(now())
}

enum Role {
  SALES
  ENGINEER
  ADMIN
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  // Primary (quick-access) contact — kept for backward compat with listings.
  // The full contact roster lives in `contacts` (JSON) with at minimum the
  // primary contact as its first entry.
  contactName  String?
  contactEmail String?
  contactPhone String?
  contacts     Json?
  // Company billing / default address. All fields optional — reps often
  // start a customer with just a name and fill in address details later
  // when a formal quote is being sent. The Quote PDF's "Prepared For"
  // block reads from here when present.
  addressLine1 String?
  addressLine2 String?
  city         String?
  region       String?
  postalCode   String?
  country      String?
  createdAt DateTime @default(now())

  projects  Project[]
  quotes    Quote[]

  @@index([tenantId])
}

model Project {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  name       String
  description String?
  customerProjectNumber String?
  siteAddress String?
  endUse     String?
  needByDate DateTime?
  createdAt  DateTime @default(now())

  quotes     Quote[]

  @@index([customerId])
}

// Note: Customer ↔ Quote is a new back-relation — projectless quotes are
// attached directly to a customer. Kept alongside the project linkage so
// tenant queries can pivot on customer regardless of project presence.

model Quote {
  id         String   @id @default(cuid())
  // Nullable — not every quote is tied to a formal project record. Sales
  // often starts a quote against a customer before the project exists.
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id])
  // Customer scope is always required — even project-less quotes need a
  // tenant-bound customer so tenant checks + listings keep working.
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  number     String   @unique
  status     QuoteStatus @default(DRAFT)
  // Quoted price (USD). Nullable — set when the sales rep sends the quote
  // or marks it WON, not required on draft rows.
  totalPrice Float?
  // Timestamp of status→WON transition. Indexed for the YTD revenue graph
  // on the dashboard; avoids rescanning AuditLog to derive close dates.
  wonAt      DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  revisions  Revision[]

  @@index([projectId])
  @@index([customerId])
  @@index([wonAt])
}

enum QuoteStatus {
  DRAFT
  SENT
  ENGINEERING
  BUILDING
  WON
  SHIPPED
  LOST
}

model Revision {
  id        String   @id @default(cuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id])
  label     String   // A, B, C, ...
  createdAt DateTime @default(now())

  service   Json?    // ServiceConditions
  site      Json?    // SeismicParameters + WindParameters
  certs     Json?    // CertificationRequirements
  geometry  Json?
  wallBuildup Json?
  outputs   Json?    // OutputArtifacts refs

  @@unique([quoteId, label])
  @@index([quoteId])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  revisionId String?
  actorUserId String
  action     String
  diffJson   Json
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
